NODE_ENV=development
PORT=3333
APP_BASE_URL=http://localhost:3333
TIMEZONE=America/Sao_Paulo

DATABASE_PATH=./data/adsbot.sqlite
BACKUP_DIR=./backups

SEARCH_TTL_MINUTES=60
SEARCH_CLEANUP_CRON=*/15 * * * *
SEARCH_MAX_RESULTS=30
SEARCH_MAX_RESULTS_PER_STORE=10
SEARCH_MAX_ITEMS_PER_STORE=30
SEARCH_CACHE_VERSION=v7-shopee-session

SCRAPER_DEFAULT_MODE=scrape
SCRAPER_USE_HEADLESS_FALLBACK=true
SCRAPER_TIMEOUT_TOTAL_MS=120000
SCRAPER_TIMEOUT_HTTP_MS=15000
SCRAPER_TIMEOUT_HEADLESS_MS=18000
SCRAPER_MAX_HEADLESS_ATTEMPTS_PER_STORE=2
SCRAPER_PRODUCT_CONCURRENCY=2
SCRAPER_CACHE_TTL_MINUTES=10
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
PROXY_URL=
SHOPEE_BROWSER_PROFILE_DIR=./data/browser-profiles/shopee

ENABLE_SCRAPING_FALLBACK=true
ENABLE_MOCK_SOURCES=false
ENABLE_SHOPEE_SEARCH=true
EXTERNAL_REQUEST_TIMEOUT_MS=15000

AMAZON_SEARCH_URL_TEMPLATE=https://www.amazon.com.br/s?k={query}
MERCADOLIVRE_SEARCH_URL_TEMPLATE=https://lista.mercadolivre.com.br/{query}
SHOPEE_SEARCH_URL_TEMPLATE=https://shopee.com.br/search?keyword={query}

# Mantidos apenas para compatibilidade com codigo legado (nao usados no pipeline de scraping)
AMAZON_FEED_URL=
AMAZON_API_KEY=
AMAZON_AFFILIATE_TAG=

MERCADOLIVRE_FEED_URL=
MERCADOLIVRE_API_KEY=
ML_AFFILIATE_ID=
MERCADOLIVRE_AFFILIATE_ID=
MERCADOLIVRE_AFFILIATE_URL_TEMPLATE=

SHOPEE_FEED_URL=
# Em ambientes bloqueados por CAPTCHA, configure um feed/API real da Shopee ou um PROXY_URL residencial.
SHOPEE_API_KEY=
SHOPEE_AFFILIATE_ID=
SHOPEE_AFFILIATE_URL_TEMPLATE=
